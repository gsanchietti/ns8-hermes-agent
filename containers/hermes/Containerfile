FROM docker.io/nousresearch/hermes-agent:v2026.4.23
LABEL org.opencontainers.image.title="hermes-agent-hermes"
LABEL org.opencontainers.image.description="Thin wrapper around the upstream Hermes runtime image"

ENV VIRTUAL_ENV=/opt/hermes/.venv
ENV PATH="${VIRTUAL_ENV}/bin:${PATH}"

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    gh \
    git \
    less \
    pip \
    python3-googleapi \
    python3-google-auth-oauthlib \
    vim

USER hermes

RUN pip install --no-cache-dir --break-system-packages \
    ddgs \
    pytesseract \
    pdf2image

COPY entrypoint.sh /entrypoint.sh

USER root

RUN cd /opt/hermes/web && npm install && npm run build

RUN apt-get clean autoclean && apt-get autoremove --yes && rm -rf /var/lib/{apt,dpkg,cache,log}/* && touch /var/lib/dpkg/status
RUN chown -R hermes:hermes /opt/hermes /opt/data

USER hermes

ENTRYPOINT [ "/entrypoint.sh" ]
