#!/usr/bin/env python3
# Migrate flat per-agent secrets files from the state root to state/secrets/.
# Idempotent: files already in their new location are left untouched.
#
#   secrets.env           → secrets/shared.env
#   agent_{N}_secrets.env → secrets/{N}.env

import re
import shutil
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))

from hermes_agent_state import SECRETS_DIR, SHARED_SECRETS_ENVFILE, ensure_private_directory

OLD_AGENT_SECRETS_PATTERN = re.compile(r"^agent_(\d+)_secrets\.env$")


def migrate_file(src, dst):
    if not src.exists():
        return
    if dst.exists():
        print(f"Already migrated, removing old: {src}", flush=True)
        src.unlink()
        return
    print(f"Migrating {src} → {dst}", flush=True)
    shutil.move(str(src), str(dst))


ensure_private_directory(SECRETS_DIR)

migrate_file(Path("secrets.env"), SHARED_SECRETS_ENVFILE)

for path in sorted(Path(".").iterdir()):
    match = OLD_AGENT_SECRETS_PATTERN.fullmatch(path.name)
    if match:
        agent_id = match.group(1)
        migrate_file(path, SECRETS_DIR / f"{agent_id}.env")
