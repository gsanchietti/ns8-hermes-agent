{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-agent-runtime output",
    "$id": "http://schema.nethserver.org/hermes-agent/get-agent-runtime-output.json",
    "description": "Get Hermes agent runtime state",
    "examples": [],
    "type": "object",
    "additionalProperties": false,
    "required": [
        "agents"
    ],
    "properties": {
        "agents": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "runtime_status"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 30
                    },
                    "runtime_status": {
                        "type": "string",
                        "enum": [
                            "start",
                            "stop"
                        ]
                    }
                }
            }
        }
    }
}