#!/usr/bin/env python3

import json
import os
import sys
from pathlib import Path

import agent
import agent.tasks

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import (
    LETS_ENCRYPT_ENV,
    env_to_bool,
    shared_route_instance_name,
)


json.load(sys.stdin)

traefik_agent_id = agent.resolve_agent_id("traefik@node")
if traefik_agent_id is None:
    sys.exit(0)

cleanup_lets_encrypt = env_to_bool(os.getenv(LETS_ENCRYPT_ENV))

# Delete the shared route first, then remove any retained legacy per-agent
# route instances from older module revisions.
route_request = {"instance": shared_route_instance_name(module_id=os.environ.get("MODULE_ID"))}
if cleanup_lets_encrypt:
    route_request["lets_encrypt_cleanup"] = True
response = agent.tasks.run(
    agent_id=traefik_agent_id,
    action="delete-route",
    data=route_request,
)
agent.assert_exp(response["exit_code"] == 0)