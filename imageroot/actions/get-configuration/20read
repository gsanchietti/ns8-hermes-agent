#!/usr/bin/env python3

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import actual_agent_status, read_agents_from_state



agents = []
for agent_data in read_agents_from_state():
	agents.append(
		{
			**agent_data,
			"runtime_status": actual_agent_status(agent_data["id"]),
		}
	)

json.dump({"agents": agents}, fp=sys.stdout)
