import json
import sys
import importlib.util
from pathlib import Path

runtime_path = Path(__file__).resolve().parents[2] / "pypkg" / "hermes_agent_runtime.py"
runtime_spec = importlib.util.spec_from_file_location("hermes_agent_runtime", runtime_path)
assert runtime_spec is not None and runtime_spec.loader is not None
runtime_module = importlib.util.module_from_spec(runtime_spec)
runtime_spec.loader.exec_module(runtime_module)


config = {
    "agents": [
        {
            **agent_data,
            "status": runtime_module.actual_agent_status(agent_data["id"]),
        }
        for agent_data in runtime_module.read_agents_from_state()
    ],
}

json.dump(config, fp=sys.stdout)
