{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-configuration output",
    "$id": "http://schema.nethserver.org/hermes-agent/get-configuration-output.json",
    "description": "Get hermes-agent configuration",
    "examples": [],
    "type": "object",
    "additionalProperties": false,
    "required": [
        "agents"
    ],
    "properties": {
        "agents": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "name",
                    "role",
                    "status",
                    "runtime_status"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z ]+$"
                    },
                    "role": {
                        "type": "string",
                        "enum": [
                            "default",
                            "developer",
                            "marketing",
                            "sales",
                            "customer_support",
                            "social_media_manager",
                            "business_consultant",
                            "researcher"
                        ]
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "start",
                            "stop"
                        ]
                    },
                    "runtime_status": {
                        "type": "string",
                        "enum": [
                            "start",
                            "stop"
                        ]
                    }
                }
            }
        }
    }
}