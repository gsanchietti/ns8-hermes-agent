#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from pathlib import Path

import agent


json.load(sys.stdin)


def ensure_state_directory(path):
    try:
        path.lstat()
    except FileNotFoundError:
        path.mkdir(mode=0o700)
    else:
        if path.is_symlink() or not path.is_dir():
            raise ValueError(f"unsafe directory path: {path}")

    os.chmod(path, 0o700)


def ensure_private_file(path):
    try:
        path.lstat()
    except FileNotFoundError:
        path.touch()
    else:
        if path.is_symlink() or not path.is_file():
            raise ValueError(f"unsafe file path: {path}")

    os.chmod(path, 0o600)

timezone = (os.getenv("TIMEZONE") or "UTC").strip() or "UTC"

agent.set_env("TIMEZONE", timezone)

ensure_state_directory(Path("agents"))
ensure_private_file(Path("secrets.env"))

subprocess.run(["runagent", "discover-smarthost"], check=True)
