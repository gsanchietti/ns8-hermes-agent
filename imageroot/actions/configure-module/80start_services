# If the control reaches this step, the service can be enabled and started

touch smarthost.env

if [[ ! -f agents.env ]]; then
	printf 'AGENTS_LIST=\n' > agents.env
fi

systemctl --user enable hermes-agent.service

if systemctl --user is-active --quiet hermes-agent.service; then
	systemctl --user restart hermes-agent.service
else
	systemctl --user start hermes-agent.service
fi
