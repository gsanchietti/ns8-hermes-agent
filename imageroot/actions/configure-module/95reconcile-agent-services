#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

import agent

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import (
    BASE_VIRTUALHOST_PREVIOUS_ENV,
    LETS_ENCRYPT_PREVIOUS_ENV,
    read_agents_from_state,
)


def run(command, check=True):
    subprocess.run(command, check=check)


def stop_disable_agent(agent_id):
    run(["systemctl", "--user", "disable", "--now", f"hermes@{agent_id}.service"], check=False)
    run(["systemctl", "--user", "stop", f"hermes-pod@{agent_id}.service"], check=False)
    run(["systemctl", "--user", "disable", "--now", f"hermes-agent@{agent_id}.service"], check=False)
    run(["podman", "pod", "rm", "--force", f"hermes-pod-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-dashboard-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-agent-{agent_id}"], check=False)


json.load(sys.stdin)

for agent_data in read_agents_from_state():
    agent_id = agent_data["id"]
    if agent_data["status"] == "start":
        run(["systemctl", "--user", "enable", f"hermes@{agent_id}.service"])
        run(["systemctl", "--user", "stop", f"hermes@{agent_id}.service"], check=False)
        run(["systemctl", "--user", "stop", f"hermes-pod@{agent_id}.service"], check=False)
        run(["systemctl", "--user", "start", f"hermes@{agent_id}.service"])
        continue

    stop_disable_agent(agent_id)

agent.unset_env(BASE_VIRTUALHOST_PREVIOUS_ENV)
agent.unset_env(LETS_ENCRYPT_PREVIOUS_ENV)