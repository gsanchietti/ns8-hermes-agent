import json
import sys
import agent
import agent.tasks
import os
import re

AGENTS_ENVFILE = "agents.env"
ALLOWED_ROLES = {"default", "developer"}
ALLOWED_STATUSES = {"start", "stop"}
NAME_PATTERN = re.compile(r"^[A-Za-z ]+$")


def validate_agents(raw_agents):
    if raw_agents is None:
        return []

    if not isinstance(raw_agents, list):
        raise ValueError("agents must be a list")

    normalized_agents = []
    seen_ids = set()

    for index, raw_agent in enumerate(raw_agents):
        if not isinstance(raw_agent, dict):
            raise ValueError(f"agent at index {index} must be an object")

        agent_id = raw_agent.get("id")
        if not isinstance(agent_id, int) or agent_id < 1:
            raise ValueError(f"agent at index {index} has an invalid id")
        if agent_id in seen_ids:
            raise ValueError(f"agent id {agent_id} is duplicated")

        name = raw_agent.get("name")
        if not isinstance(name, str):
            raise ValueError(f"agent at index {index} has an invalid name")
        name = name.strip()
        if not name or not NAME_PATTERN.fullmatch(name):
            raise ValueError(f"agent at index {index} has an invalid name")

        role = raw_agent.get("role")
        if role not in ALLOWED_ROLES:
            raise ValueError(f"agent at index {index} has an invalid role")

        status = raw_agent.get("status")
        if status not in ALLOWED_STATUSES:
            raise ValueError(f"agent at index {index} has an invalid status")

        normalized_agents.append(
            {
                "id": agent_id,
                "name": name,
                "role": role,
                "status": status,
            }
        )
        seen_ids.add(agent_id)

    return normalized_agents


def write_agents_env(agents):
    agents_list = ",".join(
        f"{agent_data['id']}:{agent_data['name']}:{agent_data['role']}"
        for agent_data in sorted(agents, key=lambda item: item["id"])
    )

    with open(AGENTS_ENVFILE + ".tmp", "w") as env_file:
        print(f"AGENTS_LIST={agents_list}", file=env_file)

    os.replace(AGENTS_ENVFILE + ".tmp", AGENTS_ENVFILE)

request = json.load(sys.stdin)
agents = validate_agents(request.get("agents", []))
write_agents_env(agents)

# TODO: do something with the request payload. For example configure a
# custom route in our web router. Here the path is hardcoded as
# 'hermes-agent'.

# Configure Traefik to route "/hermes-agent" path requests to the hermes-agent service
response = agent.tasks.run(
    agent_id=agent.resolve_agent_id('traefik@node'),
    action='set-route',
    data={
        'instance': os.environ['MODULE_ID'],
        'url':  'http://127.0.0.1:' + os.environ["TCP_PORT"],
        'http2https': False,
        'lets_encrypt': False,
        'path': '/hermes-agent',
    },
)

# Check if traefik configuration has been successfull
agent.assert_exp(response['exit_code'] == 0)
