#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

import agent

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import (
	AGENTS_DIR,
	ENVIRONMENT_FILE,
	TIMEZONE_DEFAULT,
	TIMEZONE_ENV,
	agent_metadata_path,
	container_name,
	ensure_private_directory,
	list_known_agent_ids,
	read_envfile,
	remove_agent_state,
	service_unit,
	validate_agents,
	write_jsonfile,
)


def run(command, check=True):
	subprocess.run(command, check=check)


def stop_disable_agent(agent_id):
	run(["systemctl", "--user", "disable", "--now", service_unit(agent_id)], check=False)
	run(["podman", "rm", "--force", container_name(agent_id)], check=False)



request = json.load(sys.stdin)
if not isinstance(request, dict):
	raise ValueError("configure-module input must be an object")

unexpected_fields = sorted(set(request) - {"agents"})
if unexpected_fields:
	raise ValueError(f"unexpected configure-module fields: {', '.join(unexpected_fields)}")

agents = validate_agents(request.get("agents"))
desired_ids = {agent_data["id"] for agent_data in agents}
known_ids = set(list_known_agent_ids())

if not read_envfile(ENVIRONMENT_FILE).get(TIMEZONE_ENV):
	agent.set_env(TIMEZONE_ENV, TIMEZONE_DEFAULT)

ensure_private_directory(AGENTS_DIR)

for agent_data in agents:
	write_jsonfile(agent_metadata_path(agent_data["id"]), agent_data)

for agent_id in sorted(known_ids - desired_ids):
	stop_disable_agent(agent_id)
	remove_agent_state(agent_id)

run(["runagent", "discover-smarthost"])
run(["runagent", "sync-agent-runtime"])
run(["systemctl", "--user", "daemon-reload"])

for agent_data in agents:
	agent_id = agent_data["id"]
	if agent_data["status"] == "start":
		run(["systemctl", "--user", "enable", service_unit(agent_id)])
		run(["systemctl", "--user", "stop", service_unit(agent_id)], check=False)
		run(["systemctl", "--user", "start", service_unit(agent_id)])
		continue

	stop_disable_agent(agent_id)
