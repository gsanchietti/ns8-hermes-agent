#!/usr/bin/env python3

import json
import os
import sys
from pathlib import Path

import agent

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import USER_DOMAIN_ENV
from hermes_user_domain import normalize_user_domain


request = json.load(sys.stdin)

if "user_domain" in request:
    user_domain = normalize_user_domain(request.get("user_domain"))
else:
    user_domain = normalize_user_domain(os.getenv(USER_DOMAIN_ENV))

# An empty binding list intentionally unbinds any previously selected NS8
# account domain when the module clears USER_DOMAIN.
domain_list = [user_domain] if user_domain else []

if not agent.bind_user_domains(domain_list):
    raise ValueError("failed to bind selected user domains")