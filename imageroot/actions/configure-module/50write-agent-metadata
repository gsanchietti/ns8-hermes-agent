#!/usr/bin/env python3

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import AGENTS_DIR, ensure_private_directory, write_jsonfile


def normalize_agents(raw_agents):
    normalized_agents = []

    for agent_data in raw_agents:
        normalized_agents.append(
            {
                "id": agent_data["id"],
                "name": agent_data["name"].strip(),
                "role": agent_data["role"],
                "status": agent_data["status"],
            }
        )

    return sorted(normalized_agents, key=lambda agent_data: agent_data["id"])


request = json.load(sys.stdin)

ensure_private_directory(AGENTS_DIR)

for agent_data in normalize_agents(request.get("agents", [])):
    write_jsonfile(AGENTS_DIR / str(agent_data["id"]) / "metadata.json", agent_data)