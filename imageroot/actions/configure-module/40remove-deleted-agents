#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import list_known_agent_ids


def run(command, check=True):
    subprocess.run(command, check=check)


request = json.load(sys.stdin)
desired_ids = {agent_data["id"] for agent_data in request.get("agents", [])}

# Systemd owns the steady-state runtime, so stale units, pods, and generated
# files are removed aggressively before an ID can be reused.
for agent_id in sorted(set(list_known_agent_ids()) - desired_ids):
    run(["systemctl", "--user", "disable", "--now", f"hermes-socket@{agent_id}.service"], check=False)
    run(["systemctl", "--user", "disable", "--now", f"hermes@{agent_id}.service"], check=False)
    run(["systemctl", "--user", "disable", "--now", f"hermes-auth@{agent_id}.service"], check=False)
    run(["systemctl", "--user", "stop", f"hermes-pod@{agent_id}.service"], check=False)
    run(["systemctl", "--user", "disable", "--now", f"hermes-agent@{agent_id}.service"], check=False)
    run(["podman", "pod", "rm", "--force", f"hermes-pod-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-socket-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-dashboard-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-auth-{agent_id}"], check=False)
    run(["podman", "rm", "--force", f"hermes-agent-{agent_id}"], check=False)
    run(["runagent", "remove-agent-state", "--agent-id", str(agent_id)])