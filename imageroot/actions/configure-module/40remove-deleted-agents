#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from hermes_agent_state import container_name, list_known_agent_ids, service_unit


def run(command, check=True):
    subprocess.run(command, check=check)


request = json.load(sys.stdin)
desired_ids = {agent_data["id"] for agent_data in request.get("agents", [])}

for agent_id in sorted(set(list_known_agent_ids()) - desired_ids):
    run(["systemctl", "--user", "disable", "--now", service_unit(agent_id)], check=False)
    run(["podman", "rm", "--force", container_name(agent_id)], check=False)
    run(["runagent", "remove-agent-state", "--agent-id", str(agent_id)])