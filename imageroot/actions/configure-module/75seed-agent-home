#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))


# This one-shot container seeds only files that should exist on first boot;
# later runs must preserve any SOUL.md or .env changes already made in volume.
SEED_SCRIPT = r'''
umask 077
mkdir -p "$HERMES_HOME"

ensure_safe_target() {
  target="$1"
  if [ -L "$target" ]; then
    rm -f "$target"
  elif [ -e "$target" ] && [ ! -f "$target" ]; then
    echo "unsafe seed target: $target" >&2
    exit 1
  fi
}

render_template() {
  template_path="$1"
  target_path="$2"
  role_mode="$3"
  python3 - "$template_path" "$target_path" "$role_mode" <<'PY'
import os
import sys
from pathlib import Path

template_path = Path(sys.argv[1])
target_path = Path(sys.argv[2])
role_mode = sys.argv[3]

if not template_path.is_file():
    raise SystemExit(f"missing template: {template_path}")

agent_role = os.environ["AGENT_ROLE"]
replacements = {
    "__AGENT_ID__": os.environ["AGENT_ID"],
    "__AGENT_NAME__": os.environ["AGENT_NAME"],
    "__AGENT_ROLE__": agent_role.replace("_", " ") if role_mode == "title" else agent_role,
}

content = template_path.read_text(encoding="utf-8")
for placeholder, value in replacements.items():
    content = content.replace(placeholder, value)

target_path.write_text(content, encoding="utf-8")
PY
}

# Seed files only when absent so operator edits inside the named volume survive
# reconfiguration and service restarts.
ensure_safe_target "${HERMES_HOME}/SOUL.md"
if [ ! -e "${HERMES_HOME}/SOUL.md" ]; then
  render_template "/templates/SOUL/${AGENT_ROLE}.md.in" "${HERMES_HOME}/SOUL.md" title
fi

ensure_safe_target "${HERMES_HOME}/.env"
if [ ! -e "${HERMES_HOME}/.env" ]; then
  render_template /templates/home.env.in "${HERMES_HOME}/.env" raw
fi
'''


def templates_dir():
    path = (Path(__file__).resolve().parents[2] / "templates").resolve()
    if not path.is_dir():
        raise ValueError(f"templates directory not found: {path}")
    return path


def public_env_file(agent_id):
    path = (Path.cwd() / "agents" / str(agent_id) / "agent.env").resolve()
    if not path.is_file():
        raise ValueError(f"agent env file not found: {path}")
    return path


def seed_agent_home(agent_id, templates_path):
    image = os.environ.get("HERMES_AGENT_HERMES_IMAGE")
    if not image:
        raise ValueError("HERMES_AGENT_HERMES_IMAGE is not set")

    command = [
        "podman",
        "run",
        "--rm",
        "--replace",
        "--name",
        f"hermes-agent-seed-{agent_id}",
        "--network=none",
        "--user",
        "hermes",
        "--entrypoint",
        "/bin/sh",
        "--env-file",
        str(public_env_file(agent_id)),
        "--volume",
        f"hermes-agents-home:/opt/agents:z",
        "--volume",
        f"{templates_path}:/templates:ro,z",
        image,
        "-eu",
        "-c",
        SEED_SCRIPT,
    ]
    subprocess.run(command, check=True)


request = json.load(sys.stdin)
seed_ids = sorted(agent_data["id"] for agent_data in request.get("agents", []))
templates_path = templates_dir()

for agent_id in seed_ids:
    seed_agent_home(agent_id, templates_path)