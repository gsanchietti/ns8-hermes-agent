#!/usr/bin/env python3
# Regenerate all runtime env files after a restore.  The core 10restore step
# (provided by NS8) has already unpacked state/agents/, state/secrets/,
# state/authproxy.*, and the hermes-agents-home volume.  This step rebuilds
# the authproxy-derived files and per-agent secrets projection so the module
# can start up cleanly without a full reconfigure.

import json
import subprocess
import sys

json.load(sys.stdin)

subprocess.run(["runagent", "sync-agent-runtime"], check=True)
