[Unit]
Description=Hermes agent pod %i
PartOf=hermes-agent@%i.target
Requires=hermes-agent-openviking.service
After=hermes-agent-openviking.service
Before=hermes-agent-hermes@%i.service hermes-agent-gateway@%i.service

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=PODMAN_SYSTEMD_UNIT=%n
WorkingDirectory=%S/state
ExecStartPre=/usr/local/bin/runagent discover-smarthost
ExecStartPre=/usr/local/bin/runagent sync-agent-runtime --agent-id %i
ExecStartPre=/usr/local/bin/runagent ensure-openviking-tenant --agent-id %i
ExecStartPre=-/usr/bin/podman pod rm --force hermes-agent-%i
ExecStart=/usr/bin/podman pod create --name hermes-agent-%i
ExecStop=/usr/bin/podman pod stop --ignore --time 10 hermes-agent-%i
ExecStopPost=-/usr/bin/podman pod rm --force hermes-agent-%i
TimeoutStopSec=70

[Install]
WantedBy=default.target