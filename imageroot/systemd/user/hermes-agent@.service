[Unit]
Description=Hermes agent runtime %i

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
EnvironmentFile=-%S/state/environment
WorkingDirectory=%S/state
Restart=always
KillMode=none
Type=notify
NotifyAccess=all
ExecStartPre=/usr/local/bin/runagent discover-smarthost
ExecStartPre=/usr/local/bin/runagent sync-agent-runtime --agent-id %i
ExecStartPre=-/usr/bin/podman rm --force hermes-agent-%i
ExecStart=/usr/bin/podman run \
    --name hermes-agent-%i \
    --replace \
    --rm \
    --sdnotify=conmon \
    --cgroups=no-conmon \
    --env-file %S/state/agent_%i.env \
    --env-file %S/state/agent_%i_secrets.env \
    --volume %S/state/agents/%i/home:/opt/data:z \
    --tz=${TIMEZONE} \
    ${HERMES_AGENT_HERMES_IMAGE}
ExecStop=/usr/bin/podman stop --ignore --time 10 hermes-agent-%i
ExecStopPost=-/usr/bin/podman rm --force hermes-agent-%i
TimeoutStopSec=70

[Install]
WantedBy=default.target