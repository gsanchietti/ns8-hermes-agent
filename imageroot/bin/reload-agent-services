#!/usr/bin/env python3

import subprocess
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))

from hermes_agent_runtime import read_agents_from_state, target_unit, unit_is_active


def run(command):
    subprocess.run(command, check=True)


run(["runagent", "discover-smarthost"])
run(["runagent", "sync-agent-runtime"])

for agent_data in read_agents_from_state():
    agent_target = target_unit(agent_data["id"])
    if unit_is_active(agent_target):
        run(["systemctl", "--user", "stop", agent_target])
        run(["systemctl", "--user", "start", agent_target])

sys.exit(0)