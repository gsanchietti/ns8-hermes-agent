#!/usr/bin/env python3

import argparse
import shutil
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))

from hermes_agent_state import MAX_AGENTS


def parse_agent_id(value):
    agent_id = int(value)
    if 1 <= agent_id <= MAX_AGENTS:
        return agent_id
    raise argparse.ArgumentTypeError(f"agent id must be between 1 and {MAX_AGENTS}")


def ensure_volume_removed(agent_id):
    exists_result = subprocess.run(
        ["podman", "volume", "exists", f"hermes-agent-{agent_id}-home"],
        check=False,
    )
    if exists_result.returncode == 0:
        subprocess.run(["podman", "volume", "rm", "--force", f"hermes-agent-{agent_id}-home"], check=True)
        return
    if exists_result.returncode == 1:
        return
    raise RuntimeError(f"failed to inspect volume hermes-agent-{agent_id}-home")


def remove_agent_state(agent_id):
    ensure_volume_removed(agent_id)

    for path in (Path(f"agent_{agent_id}.env"), Path(f"agent_{agent_id}_secrets.env")):
        if path.exists():
            path.unlink()

    agent_state_dir = Path("agents") / str(agent_id)
    if agent_state_dir.exists():
        shutil.rmtree(agent_state_dir, ignore_errors=True)


def main():
    parser = argparse.ArgumentParser(description="Remove generated state for one Hermes agent")
    parser.add_argument("--agent-id", type=parse_agent_id, required=True, help="Remove state for one agent")
    args = parser.parse_args()

    remove_agent_state(args.agent_id)
    return 0


if __name__ == "__main__":
    sys.exit(main())