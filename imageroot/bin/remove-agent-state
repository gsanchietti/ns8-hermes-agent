#!/usr/bin/env python3

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))

from hermes_agent_state import AGENT_DASHBOARD_SOCKETS_DIR, AGENTS_HOME_VOLUME, MAX_AGENTS, SECRETS_DIR, agent_dashboard_socket_name


def parse_agent_id(value):
    agent_id = int(value)
    if 1 <= agent_id <= MAX_AGENTS:
        return agent_id
    raise argparse.ArgumentTypeError(f"agent id must be between 1 and {MAX_AGENTS}")


def remove_agent_home_subdir(agent_id):
    image = os.environ.get("HERMES_AGENT_HERMES_IMAGE")
    if not image:
        raise ValueError("HERMES_AGENT_HERMES_IMAGE is not set")

    exists_result = subprocess.run(
        ["podman", "volume", "exists", AGENTS_HOME_VOLUME],
        check=False,
    )
    if exists_result.returncode != 0:
        return

    subprocess.run(
        [
            "podman", "run",
            "--rm",
            "--replace",
            "--name", f"hermes-agent-cleanup-{agent_id}",
            "--network=none",
            "--user", "root",
            "--entrypoint", "/bin/sh",
            "--volume", f"{AGENTS_HOME_VOLUME}:/opt/agents:z",
            image,
            "-c", f"rm -rf /opt/agents/{agent_id}",
        ],
        check=True,
    )


def remove_agent_state(agent_id):
    # Remove all generated runtime artifacts for an agent ID so future
    # reconfiguration starts from clean metadata, env files, and home volume.
    remove_agent_home_subdir(agent_id)

    agent_secrets_path = SECRETS_DIR / f"{agent_id}.env"
    if agent_secrets_path.exists():
        agent_secrets_path.unlink()

    dashboard_socket_path = AGENT_DASHBOARD_SOCKETS_DIR / agent_dashboard_socket_name(agent_id)
    if dashboard_socket_path.exists() or dashboard_socket_path.is_symlink():
        dashboard_socket_path.unlink()

    agent_state_dir = Path("agents") / str(agent_id)
    if agent_state_dir.exists():
        shutil.rmtree(agent_state_dir, ignore_errors=True)


def main():
    parser = argparse.ArgumentParser(description="Remove generated state for one Hermes agent")
    parser.add_argument("--agent-id", type=parse_agent_id, required=True, help="Remove state for one agent")
    args = parser.parse_args()

    remove_agent_state(args.agent_id)
    return 0


if __name__ == "__main__":
    sys.exit(main())