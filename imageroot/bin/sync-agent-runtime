#!/usr/bin/env python3

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))
from hermes_agent_runtime import sync_agent_runtime_files


def main():
    parser = argparse.ArgumentParser(description="Generate per-agent runtime env files")
    parser.add_argument("--agent-id", type=int, help="Sync only one agent")
    args = parser.parse_args()

    try:
        sync_agent_runtime_files(agent_id=args.agent_id)
    except ValueError as error:
        print(str(error), file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())