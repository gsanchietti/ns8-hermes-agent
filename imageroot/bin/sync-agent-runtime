#!/usr/bin/env python3

import argparse
import os
import secrets
import sys
from pathlib import Path

import agent

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))

from hermes_agent_state import (
    AGENT_SECRET_KEY,
    AGENT_ALLOWED_USER_ENV,
    AGENT_DASHBOARD_HOST_PORT_ENV,
    BASE_VIRTUALHOST_ENV,
    SMTP_PUBLIC_KEYS,
    SMTP_SECRET_KEY,
    USER_DOMAIN_ENV,
    agent_dashboard_host_port,
    read_agents_from_state,
)
from hermes_user_domain import public_runtime_env, secrets_runtime_env


def timezone_value(shared_environment=None):
    if shared_environment is None:
        shared_environment = os.environ

    value = (shared_environment.get("TIMEZONE") or "UTC").strip()
    return value or "UTC"


def generate_secret():
    return secrets.token_hex(16)


def read_optional_envfile(path):
    if not os.path.exists(path):
        return {}

    return agent.read_envfile(path)


def agent_by_id(agent_id):
    for agent_data in read_agents_from_state():
        if agent_data["id"] == agent_id:
            return agent_data

    raise ValueError(f"agent {agent_id} not found")


def build_agent_public_env(agent_data, shared_environment):
    # Containers only consume generated per-agent env files, so copy the shared
    # public settings they need and overlay agent-specific fields here.
    env_data = {
        "AGENT_ID": str(agent_data["id"]),
        "AGENT_NAME": agent_data["name"],
        "AGENT_ROLE": agent_data["role"],
        "TIMEZONE": timezone_value(shared_environment),
        "TZ": timezone_value(shared_environment),
        AGENT_DASHBOARD_HOST_PORT_ENV: str(agent_dashboard_host_port(agent_data["id"], shared_environment)),
    }

    base_virtualhost = (shared_environment.get(BASE_VIRTUALHOST_ENV) or "").strip().lower()
    if base_virtualhost:
        env_data[BASE_VIRTUALHOST_ENV] = base_virtualhost

    allowed_user = (agent_data.get("allowed_user") or "").strip()
    if allowed_user:
        env_data[AGENT_ALLOWED_USER_ENV] = allowed_user

    user_domain = (shared_environment.get(USER_DOMAIN_ENV) or "").strip().lower()
    if user_domain:
        env_data.update(public_runtime_env(user_domain))

    for key in SMTP_PUBLIC_KEYS:
        value = shared_environment.get(key)
        if value:
            env_data[key] = value

    return env_data


def build_agent_secrets(existing_agent_secrets, shared_secrets, shared_environment):
    # Preserve each agent secret across regenerations while still projecting the
    # current module-wide SMTP and LDAP bind credentials into the private file.
    env_data = {
        AGENT_SECRET_KEY: existing_agent_secrets.get(AGENT_SECRET_KEY) or generate_secret(),
    }

    smtp_password = shared_secrets.get(SMTP_SECRET_KEY)
    if smtp_password:
        env_data[SMTP_SECRET_KEY] = smtp_password

    user_domain = (shared_environment.get(USER_DOMAIN_ENV) or "").strip().lower()
    if user_domain:
        env_data.update(secrets_runtime_env(user_domain))

    return env_data


def sync_agent_runtime_files(agent_id=None):
    shared_environment = agent.read_envfile("environment")
    shared_secrets = agent.read_envfile("secrets.env")
    agent_data_list = [agent_by_id(agent_id)] if agent_id is not None else read_agents_from_state()

    for agent_data in agent_data_list:
        # Regenerate both files from the canonical shared state so systemd unit
        # restarts always see a complete, current runtime snapshot.
        agent.write_envfile(
            Path(f"agent_{agent_data['id']}.env"),
            build_agent_public_env(agent_data, shared_environment),
        )
        existing_agent_secrets = read_optional_envfile(Path(f"agent_{agent_data['id']}_secrets.env"))
        agent_secrets = build_agent_secrets(existing_agent_secrets, shared_secrets, shared_environment)
        agent.write_envfile(
            Path(f"agent_{agent_data['id']}_secrets.env"),
            agent_secrets,
        )


def main():
    parser = argparse.ArgumentParser(description="Generate per-agent runtime env files")
    parser.add_argument("--agent-id", type=int, help="Sync only one agent")
    args = parser.parse_args()

    try:
        sync_agent_runtime_files(agent_id=args.agent_id)
    except ValueError as error:
        print(str(error), file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())