#!/usr/bin/env python3

import argparse
import os
import secrets
import sys
from pathlib import Path

import agent

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "pypkg"))

from hermes_agent_state import (
    AGENT_SECRET_KEY,
    AGENT_DASHBOARD_HOST_PORT_ENV,
    BASE_VIRTUALHOST_ENV,
    SMTP_PUBLIC_KEYS,
    SMTP_SECRET_KEY,
    agent_envfile,
    agent_dashboard_host_port,
    agent_secrets_envfile,
    read_agents_from_state,
)


def timezone_value(shared_environment=None):
    if shared_environment is None:
        shared_environment = os.environ

    value = (shared_environment.get("TIMEZONE") or "UTC").strip()
    return value or "UTC"


def generate_secret():
    return secrets.token_hex(16)


def agent_by_id(agent_id):
    for agent_data in read_agents_from_state():
        if agent_data["id"] == agent_id:
            return agent_data

    raise ValueError(f"agent {agent_id} not found")


def build_agent_public_env(agent_data, shared_environment):
    env_data = {
        "AGENT_ID": str(agent_data["id"]),
        "AGENT_NAME": agent_data["name"],
        "AGENT_ROLE": agent_data["role"],
        "TIMEZONE": timezone_value(shared_environment),
        "TZ": timezone_value(shared_environment),
        AGENT_DASHBOARD_HOST_PORT_ENV: str(agent_dashboard_host_port(agent_data["id"], shared_environment)),
    }

    base_virtualhost = (shared_environment.get(BASE_VIRTUALHOST_ENV) or "").strip().lower()
    if base_virtualhost:
        env_data[BASE_VIRTUALHOST_ENV] = base_virtualhost

    for key in SMTP_PUBLIC_KEYS:
        value = shared_environment.get(key)
        if value:
            env_data[key] = value

    return env_data


def build_agent_secrets(existing_agent_secrets, shared_secrets):
    env_data = {
        AGENT_SECRET_KEY: existing_agent_secrets.get(AGENT_SECRET_KEY) or generate_secret(),
    }

    smtp_password = shared_secrets.get(SMTP_SECRET_KEY)
    if smtp_password:
        env_data[SMTP_SECRET_KEY] = smtp_password

    return env_data


def sync_agent_runtime_files(agent_id=None):
    shared_environment = agent.read_envfile("environment")
    shared_secrets = agent.read_envfile("secrets.env")
    agent_data_list = [agent_by_id(agent_id)] if agent_id is not None else read_agents_from_state()

    for agent_data in agent_data_list:
        agent.write_envfile(agent_envfile(agent_data["id"]), build_agent_public_env(agent_data, shared_environment))
        existing_agent_secrets = agent.read_envfile(agent_secrets_envfile(agent_data["id"]))
        agent_secrets = build_agent_secrets(existing_agent_secrets, shared_secrets)
        agent.write_envfile(
            agent_secrets_envfile(agent_data["id"]),
            agent_secrets,
        )


def main():
    parser = argparse.ArgumentParser(description="Generate per-agent runtime env files")
    parser.add_argument("--agent-id", type=int, help="Sync only one agent")
    args = parser.parse_args()

    try:
        sync_agent_runtime_files(agent_id=args.agent_id)
    except ValueError as error:
        print(str(error), file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())